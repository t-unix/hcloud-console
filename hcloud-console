#!/usr/bin/env python3
"""hcloud-console <server> [-- extra hcloud args]

Wraps `hcloud server request-console` and opens a noVNC session in the
default browser. Serves the local noVNC client over 127.0.0.1.

Requires noVNC at ~/.local/share/novnc (override with $HCLOUD_CONSOLE_NOVNC_DIR).
"""

from __future__ import annotations

import argparse
import http.server
import os
import re
import socket
import socketserver
import subprocess
import sys
import threading
import time
import urllib.parse
import webbrowser
from pathlib import Path

DEFAULT_NOVNC_DIR = Path.home() / ".local" / "share" / "novnc"
ANSI_RE = re.compile(r"\x1b\[[0-9;?]*[ -/]*[@-~]")


def parse_hcloud_output(text: str) -> tuple[str, str]:
    text = ANSI_RE.sub("", text)
    ws = re.search(r"WebSocket URL:\s*(\S+)", text)
    pw = re.search(r"VNC Password:\s*(\S+)", text)
    if not ws or not pw:
        raise ValueError(f"could not parse hcloud output:\n{text}")
    return ws.group(1), pw.group(1)


def split_ws_url(url: str) -> tuple[str, int, str]:
    p = urllib.parse.urlparse(url)
    if p.scheme not in ("ws", "wss"):
        raise ValueError(f"unexpected scheme {p.scheme!r} in {url}")
    host = p.hostname or ""
    port = p.port or (443 if p.scheme == "wss" else 80)
    path = p.path.lstrip("/")
    if p.query:
        path = f"{path}?{p.query}"
    return host, port, path


def build_novnc_url(local_port: int, ws_url: str, password: str) -> str:
    host, port, path = split_ws_url(ws_url)
    params = {
        "autoconnect": 1,
        "encrypt": 1,
        "host": host,
        "port": port,
        "path": path,
        "password": password,
        "resize": "scale",
        "reconnect": 1,
    }
    return f"http://127.0.0.1:{local_port}/vnc.html?{urllib.parse.urlencode(params)}"


def request_console(server: str, extra: list[str]) -> str:
    cmd = ["hcloud", "server", "request-console", server, *extra]
    proc = subprocess.run(cmd, capture_output=True, text=True)
    if proc.returncode != 0:
        sys.stderr.write(proc.stdout)
        sys.stderr.write(proc.stderr)
        sys.exit(f"hcloud exited with status {proc.returncode}")
    return proc.stdout + proc.stderr


def serve_dir(directory: Path) -> tuple[int, socketserver.TCPServer]:
    class Handler(http.server.SimpleHTTPRequestHandler):
        def __init__(self, *a, **kw):
            super().__init__(*a, directory=str(directory), **kw)

        def log_message(self, *args, **kwargs):
            pass

    httpd = socketserver.TCPServer(("127.0.0.1", 0), Handler)
    threading.Thread(target=httpd.serve_forever, daemon=True).start()
    return httpd.server_address[1], httpd


def main(argv: list[str]) -> int:
    ap = argparse.ArgumentParser(
        prog="hcloud-console",
        description="Open a Hetzner Cloud server console in the browser via noVNC.",
    )
    ap.add_argument("server", help="server id or name")
    ap.add_argument(
        "--from-stdin",
        action="store_true",
        help="read hcloud output from stdin instead of running hcloud (for testing)",
    )
    ap.add_argument(
        "--print-only",
        action="store_true",
        help="print the noVNC URL and exit; do not start a server or open a browser",
    )
    ap.add_argument(
        "--novnc-dir",
        default=os.environ.get("HCLOUD_CONSOLE_NOVNC_DIR", str(DEFAULT_NOVNC_DIR)),
        help=f"directory containing vnc.html (default: {DEFAULT_NOVNC_DIR})",
    )
    ap.add_argument(
        "hcloud_args",
        nargs=argparse.REMAINDER,
        help="extra args passed through to hcloud (after --)",
    )
    args = ap.parse_args(argv)

    novnc_dir = Path(args.novnc_dir).expanduser()
    if not (novnc_dir / "vnc.html").is_file() and not args.print_only:
        sys.exit(
            f"noVNC vnc.html not found at {novnc_dir}.\n"
            "Install with:\n"
            "  curl -sSL https://github.com/novnc/noVNC/archive/refs/tags/v1.7.0.tar.gz "
            "| tar -xz -C ~/.local/share && mv ~/.local/share/noVNC-1.7.0 ~/.local/share/novnc"
        )

    extra = args.hcloud_args
    if extra and extra[0] == "--":
        extra = extra[1:]

    if args.from_stdin:
        raw = sys.stdin.read()
    else:
        print(f"Requesting console for {args.server}...", file=sys.stderr)
        raw = request_console(args.server, extra)

    ws_url, password = parse_hcloud_output(raw)

    if args.print_only:
        # Use a placeholder local port — real serve happens below otherwise.
        url = build_novnc_url(0, ws_url, password)
        print(url)
        return 0

    local_port, httpd = serve_dir(novnc_dir)
    url = build_novnc_url(local_port, ws_url, password)

    print(f"noVNC URL: {url}", file=sys.stderr)
    if not webbrowser.open(url):
        print("Could not auto-open a browser; copy the URL above.", file=sys.stderr)
    print("Local noVNC server running. Press Ctrl+C to stop.", file=sys.stderr)
    try:
        while True:
            time.sleep(1)
    except KeyboardInterrupt:
        httpd.shutdown()
        print("Stopped.", file=sys.stderr)
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
